# Gitignore bylo vybudováno za pomoci AI
# ----------------------------------------------------------------------------
# 1. Rust Build Artifacts
# ----------------------------------------------------------------------------
/target/
**/*.rs.bk

# ----------------------------------------------------------------------------
# 2. Node.js & NPM (Tailwind/DaisyUI dependencies)
# ----------------------------------------------------------------------------
node_modules/

# ----------------------------------------------------------------------------
# 3. Dioxus & Tailwind Generated Files
# ----------------------------------------------------------------------------
# Note: If the tailwind.css in your root is your INPUT file (where you write 
# @tailwind base;), remove this line! 
# If it's the OUTPUT file that gets rewritten on dx serve, leave it here.
/tailwind.css

# (Optional) If Dioxus outputs your final CSS into the assets folder instead:
# /assets/tailwind.css

# The default folder where Dioxus builds your final release app
/dist/

# ----------------------------------------------------------------------------
# 4. OS & Editor Files (Standard cleanup)
# ----------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
